{
  "name": "pi-skill-optimizer",
  "version": "1.0.1",
  "private": false,
  "type": "module",
  "description": "A Pi extension that cuts input-token cost every request — slims the <available_skills> catalog, the tools array, and noisy tool output — without hiding your skills. Provider-agnostic, config-driven, cross-OS.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "optimization",
    "tokens",
    "skills",
    "system-prompt",
    "tool-output",
    "mcp"
  ],
  "license": "MIT",
  "author": "AeonDave",
  "homepage": "https://github.com/AeonDave/pi-skill-optimizer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AeonDave/pi-skill-optimizer.git"
  },
  "bugs": {
    "url": "https://github.com/AeonDave/pi-skill-optimizer/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/skills.test.ts test/tools.test.ts test/optimize.test.ts test/profile.test.ts test/generate.test.ts test/config.test.ts test/fuzz.test.ts test/output.test.ts test/stats.test.ts",
    "measure": "node --import tsx scripts/measure.ts",
    "bench": "node --import tsx scripts/bench.ts"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
